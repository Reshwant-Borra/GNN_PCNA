---
title: Data Flow
---
flowchart TD
    subgraph RAW["data/raw/"]
        R1["1W60.pdb"]
        R2["8GLA.pdb"]
        R3["cryptosite_*.pdb"]
    end

    subgraph PROC["data/processed/"]
        P1["1W60_clean.pdb\n(no water, std chains)"]
        P2["8GLA_clean.pdb"]
        P3["cryptosite_clean/*.pdb"]
    end

    subgraph GRAPHS["data/graphs/"]
        G1["pcna_apo.pt\n(N=267 monomer)"]
        G2["pcna_holo.pt\n(N=267 + labels)"]
        G3["cryptosite_train/*.pt"]
    end

    subgraph LABELS["data/labels/"]
        L1["pcna_8GLA_labels.npy\n(shape: N,)"]
    end

    subgraph TRAJ["data/trajectories/"]
        T1["pcna_100ns.xtc"]
        T2["pcna_topology.gro"]
    end

    subgraph CKPT["checkpoints/"]
        C1["pretrain_cryptosite.ckpt"]
        C2["finetune_pcna.ckpt"]
    end

    subgraph RESULTS["results/"]
        RES1["pockets/candidates.json"]
        RES2["pockets/scored.pdb"]
        RES3["validated/pocket_1_rmsf.npy"]
        RES4["validated/pocket_1_dccm.npy"]
        RES5["validated/summary.json"]
    end

    R1 -->|"strip + clean"| P1
    R2 -->|"strip + clean"| P2
    R3 -->|"strip + clean"| P3
    P1 -->|"graph_construction.py"| G1
    P2 -->|"graph_construction.py\n+ label_pockets.py"| G2
    P2 -->|"label_pockets.py"| L1
    P3 -->|"graph_construction.py"| G3
    G3 -->|"train.py (pretrain)"| C1
    G2 & L1 -->|"train.py (finetune)"| C2
    C2 -->|"predict.py"| RES1
    RES1 -->|"score_pockets.py"| RES2
    T1 & T2 -->|"parse_trajectory.py"| RES3
    T1 & T2 -->|"parse_trajectory.py"| RES4
    RES3 & RES4 & RES1 -->|"validate_pockets.py"| RES5

    style RAW fill:#1e3a5f,color:#fff
    style PROC fill:#1a4731,color:#fff
    style GRAPHS fill:#3d2b00,color:#fff
    style LABELS fill:#2a2a00,color:#fff
    style TRAJ fill:#1a3a3a,color:#fff
    style CKPT fill:#3b1f3f,color:#fff
    style RESULTS fill:#3a1a1a,color:#fff
