---
title: Experiment Lifecycle
---
flowchart TD
    IDEA["💡 Idea / Task"]
    BRAIN["Read Brain\ndocs/knowledge/INDEX.md\n+ relevant files"]
    PLAN["Claude Creates Plan\ndocs/plans/YYYY-MM-DD_slug.md"]
    REVIEW["Plan Review\nby researcher"]
    GEMINI["Gemini Implements\nfrom GEMINI TASK block"]
    CODE["Code applied\nto src/"]
    CHATGPT["ChatGPT Reviews\nfrom REVIEW TASK block"]
    FIXES["Fixes applied"]
    RUN["Run Experiment\npython src/..."]
    EVAL["Evaluate Results\nAUROC · AUPRC\nRMSF · DCCM"]
    PASS{"Positive control\npasses?"}
    LOG_EXP["Log Experiment\ndocs/experiments/E0XX_*.md"]
    LOG_IDX["Update Index\nEXPERIMENT_INDEX.md"]
    NEXT["Define Next Experiment"]
    PIVOT["Debug / Pivot\nupdate KNOWN_BUGS.md"]

    IDEA --> BRAIN
    BRAIN --> PLAN
    PLAN --> REVIEW
    REVIEW --> GEMINI
    GEMINI --> CODE
    CODE --> CHATGPT
    CHATGPT --> FIXES
    FIXES --> RUN
    RUN --> EVAL
    EVAL --> PASS
    PASS -->|"Yes"| LOG_EXP
    PASS -->|"No"| PIVOT
    PIVOT --> PLAN
    LOG_EXP --> LOG_IDX
    LOG_IDX --> NEXT
    NEXT --> IDEA

    style IDEA fill:#1e3a5f,color:#fff
    style PLAN fill:#3b1f3f,color:#fff
    style GEMINI fill:#1a4731,color:#fff
    style CHATGPT fill:#3d2b00,color:#fff
    style PASS fill:#3a1a1a,color:#fff
    style LOG_EXP fill:#1a3a3a,color:#fff
    style PIVOT fill:#4a1a1a,color:#fff
